<Window x:Class="IsparkDownloader2.Views.BrowserSimWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="浏览器模拟设置"
        Height="680" Width="760"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="{StaticResource FontFamilyBase}"
        FontSize="13"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="浏览器模拟设置" Foreground="{StaticResource TextPrimaryBrush}" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- 启用模拟 -->
                <CheckBox x:Name="EnableSimCheckBox" Content="启用浏览器模拟（防止403拒绝）" Style="{StaticResource ModernCheckBox}" Margin="0,0,0,15"/>

                <!-- 自动导入区域 -->
                <TextBlock Text="自动导入浏览器数据" Foreground="{StaticResource AccentBrush}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <Border Background="{StaticResource BgElevatedBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="16" Margin="0,4">
                    <StackPanel>
                        <TextBlock Text="检测到的浏览器:" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                        <ListBox x:Name="DetectedBrowsersListBox"
                                 Background="Transparent" BorderThickness="0"
                                 MaxHeight="120">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="2">
                                        <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text=" (已检测)" Foreground="{StaticResource SuccessBrush}" FontSize="11" Margin="6,0,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="DomainFilterTextBox" Style="{StaticResource ModernTextBox}" Grid.Column="0"
                                     ToolTip="留空导入所有域名，输入域名可过滤（如 baidu.com）"/>
                            <Button Content="一键导入全部" Style="{StaticResource PrimaryButton}" Grid.Column="1"
                                    Click="AutoImportAll_Click" Padding="16,8" Margin="10,0,0,0"/>
                        </Grid>
                        <TextBlock Text="提示：留空域名可导入所有 Cookie 和 LocalStorage" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,4"/>
                        <TextBlock x:Name="ImportStatusText" Text="" Foreground="{StaticResource SuccessBrush}" FontSize="12" Margin="0,4"/>

                        <Separator Background="{StaticResource BorderBrush}" Height="1" Margin="0,10"/>

                        <TextBlock Text="从文件导入:" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="导入 JSON 文件" Style="{StaticResource BaseButton}" Click="ImportJson_Click" Padding="12,6"/>
                            <Button Content="导入 Netscape 文件" Style="{StaticResource BaseButton}" Click="ImportNetscape_Click" Padding="12,6"/>
                        </StackPanel>
                        <TextBlock Text="支持 Chrome Cookie-Editor 导出的 JSON 和 Netscape 格式" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,4"/>
                    </StackPanel>
                </Border>

                <Separator Background="{StaticResource BorderBrush}" Height="1" Margin="0,12"/>

                <!-- User-Agent -->
                <TextBlock Text="User-Agent" Foreground="{StaticResource AccentBrush}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <Border Background="{StaticResource BgElevatedBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="16" Margin="0,4">
                    <StackPanel>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="User-Agent:" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBox x:Name="UserAgentTextBox" Style="{StaticResource ModernTextBox}" Grid.Column="1"/>
                            <Button Content="随机" Style="{StaticResource BaseButton}" Grid.Column="2" Click="RandomizeUA_Click" Padding="12,6" Margin="6,0,0,0"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Separator Background="{StaticResource BorderBrush}" Height="1" Margin="0,12"/>

                <!-- 语言与Referer -->
                <TextBlock Text="请求头设置" Foreground="{StaticResource AccentBrush}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <Border Background="{StaticResource BgElevatedBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="16" Margin="0,4">
                    <StackPanel>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Accept-Language:" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBox x:Name="AcceptLanguageTextBox" Style="{StaticResource ModernTextBox}" Grid.Column="1"/>
                        </Grid>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Referer:" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBox x:Name="RefererTextBox" Style="{StaticResource ModernTextBox}" Grid.Column="1"/>
                        </Grid>
                        <CheckBox x:Name="DntCheckBox" Content="发送 Do-Not-Track 请求头" Style="{StaticResource ModernCheckBox}" Margin="0,4"/>
                    </StackPanel>
                </Border>

                <Separator Background="{StaticResource BorderBrush}" Height="1" Margin="0,12"/>

                <!-- Cookie 管理 -->
                <TextBlock Text="Cookie 管理" Foreground="{StaticResource AccentBrush}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <Border Background="{StaticResource BgElevatedBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="16" Margin="0,4">
                    <StackPanel>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="域名:" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBox x:Name="CookieDomainTextBox" Style="{StaticResource ModernTextBox}" Grid.Column="1"/>
                        </Grid>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="名称:" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBox x:Name="CookieNameTextBox" Style="{StaticResource ModernTextBox}" Grid.Column="1"/>
                        </Grid>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="值:" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBox x:Name="CookieValueTextBox" Style="{StaticResource ModernTextBox}" Grid.Column="1"/>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Margin="0,8">
                            <Button Content="添加 Cookie" Style="{StaticResource PrimaryButton}" Click="AddCookie_Click" Padding="12,6"/>
                            <Button Content="清除全部 Cookie" Style="{StaticResource DangerButton}" Click="ClearCookies_Click" Padding="12,6"/>
                        </StackPanel>
                        <TextBlock x:Name="CookieStatusText" Text="" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                    </StackPanel>
                </Border>

                <Separator Background="{StaticResource BorderBrush}" Height="1" Margin="0,12"/>

                <!-- LocalStorage -->
                <TextBlock Text="LocalStorage 管理" Foreground="{StaticResource AccentBrush}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <Border Background="{StaticResource BgElevatedBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="16" Margin="0,4">
                    <StackPanel>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Key:" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBox x:Name="LSKeyTextBox" Style="{StaticResource ModernTextBox}" Grid.Column="1"/>
                        </Grid>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Value:" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBox x:Name="LSValueTextBox" Style="{StaticResource ModernTextBox}" Grid.Column="1"/>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Margin="0,8">
                            <Button Content="添加" Style="{StaticResource PrimaryButton}" Click="AddLocalStorage_Click" Padding="12,6"/>
                            <Button Content="清除全部" Style="{StaticResource DangerButton}" Click="ClearLocalStorage_Click" Padding="12,6"/>
                        </StackPanel>
                        <TextBlock x:Name="LocalStorageStatusText" Text="" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                    </StackPanel>
                </Border>

                <Separator Background="{StaticResource BorderBrush}" Height="1" Margin="0,12"/>

                <!-- 自定义请求头 -->
                <TextBlock Text="自定义请求头" Foreground="{StaticResource AccentBrush}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <Border Background="{StaticResource BgElevatedBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="16" Margin="0,4">
                    <StackPanel>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Header:" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBox x:Name="CustomHeaderKeyTextBox" Style="{StaticResource ModernTextBox}" Grid.Column="1"/>
                        </Grid>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Value:" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBox x:Name="CustomHeaderValueTextBox" Style="{StaticResource ModernTextBox}" Grid.Column="1"/>
                        </Grid>
                        <Button Content="添加自定义请求头" Style="{StaticResource PrimaryButton}" Click="AddCustomHeader_Click" Padding="12,6" HorizontalAlignment="Left" Margin="0,8"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="随机化指纹" Style="{StaticResource BaseButton}" Click="RandomizeFingerprint_Click" Padding="16,8"/>
            <Button Content="保存" Style="{StaticResource PrimaryButton}" Click="SaveButton_Click" Padding="24,8" Margin="10,0,0,0"/>
            <Button Content="取消" Style="{StaticResource BaseButton}" Click="CancelButton_Click" Padding="24,8"/>
        </StackPanel>
    </Grid>
</Window>
