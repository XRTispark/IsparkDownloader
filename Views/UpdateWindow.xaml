<Window x:Class="IsparkDownloader2.Views.UpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="发现新版本"
        Height="480" Width="520"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="{StaticResource FontFamilyBase}"
        FontSize="13"
        ResizeMode="NoResize">

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,18">
            <TextBlock Text="&#x1F680;" FontSize="26" Margin="0,0,12,0" VerticalAlignment="Center"/>
            <StackPanel>
                <TextBlock Text="发现新版本" Foreground="{StaticResource TextPrimaryBrush}" FontSize="20" FontWeight="Bold"/>
                <TextBlock x:Name="VersionText" Text="最新版本: v1.0.0" Foreground="{StaticResource AccentBrush}" FontSize="13" Margin="0,2,0,0"/>
            </StackPanel>
        </StackPanel>

        <!-- Version comparison -->
        <Border Grid.Row="1" Background="{StaticResource BgElevatedBrush}" CornerRadius="10" Margin="0,0,0,16" Padding="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="18,14">
                    <TextBlock Text="当前版本" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,0,0,4"/>
                    <TextBlock x:Name="CurrentVersionText" Text="v1.0.0" Foreground="{StaticResource TextPrimaryBrush}" FontSize="16" FontWeight="Bold"/>
                </StackPanel>
                <TextBlock Grid.Column="1" Text="&#x2192;" Foreground="{StaticResource AccentBrush}" FontSize="20" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="2" Margin="18,14">
                    <TextBlock Text="最新版本" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,0,0,4"/>
                    <TextBlock x:Name="NewVersionText" Text="v1.1.0" Foreground="{StaticResource AccentBrush}" FontSize="16" FontWeight="Bold"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Release info -->
        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <TextBlock Text="发布日期" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,0,0,2"/>
            <TextBlock x:Name="ReleaseDateText" Text="2026-01-01" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13" Margin="0,0,0,10"/>
            <TextBlock Text="更新内容" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,0,0,4"/>
        </StackPanel>

        <!-- Release notes -->
        <Border Grid.Row="3" Background="{StaticResource BgElevatedBrush}" CornerRadius="10" Margin="0,0,0,16">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="12">
                <TextBlock x:Name="ReleaseNotesText"
                           Text="- 修复了一些已知问题"
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" TextWrapping="Wrap"
                           LineHeight="20"/>
            </ScrollViewer>
        </Border>

        <!-- Progress -->
        <Grid Grid.Row="4" x:Name="ProgressPanel" Visibility="Collapsed" Margin="0,0,0,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <ProgressBar x:Name="UpdateProgressBar" Grid.Row="0"
                         Minimum="0" Maximum="1" Value="0"
                         Height="6" Background="{StaticResource BgSurfaceBrush}" Foreground="{StaticResource AccentBrush}"
                         BorderThickness="0"/>
            <TextBlock x:Name="ProgressText" Grid.Row="1"
                       Text="正在下载更新... 0%" Foreground="{StaticResource TextMutedBrush}" FontSize="11"
                       HorizontalAlignment="Center" Margin="0,6,0,0"/>
        </Grid>

        <!-- Buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="UpdateNowButton" Content="&#x2B07; 立即更新" Style="{StaticResource PrimaryButton}" Click="UpdateNow_Click" Padding="20,9"/>
            <Button x:Name="LaterButton" Content="稍后提醒" Style="{StaticResource BaseButton}" Click="Later_Click" Padding="20,9"/>
            <Button x:Name="SkipButton" Content="跳过此版本" Style="{StaticResource GhostButton}" Click="Skip_Click" Padding="20,9"/>
        </StackPanel>
    </Grid>
</Window>
