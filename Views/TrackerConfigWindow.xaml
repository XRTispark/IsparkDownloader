<Window x:Class="IsparkDownloader2.Views.TrackerConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tracker 配置"
        Height="550" Width="650"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="{StaticResource FontFamilyBase}"
        FontSize="13"
        ResizeMode="NoResize">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Tracker 配置" Foreground="{StaticResource TextPrimaryBrush}" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>

        <TabControl Grid.Row="1" Style="{StaticResource ModernTabControl}">
            <TabItem Header="通用 Tracker" Style="{StaticResource ModernTabItem}">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBox x:Name="NewTrackerTextBox"
                                 Style="{StaticResource ModernTextBox}"
                                 Width="350"
                                 ToolTip="输入 Tracker URL (如 udp://tracker.opentrackr.org:1337/announce)"/>
                        <Button Content="添加" Style="{StaticResource PrimaryButton}" Click="AddTracker_Click" Margin="10,0,0,0"/>
                        <Button Content="从 TXT 导入" Style="{StaticResource BaseButton}" Click="ImportTxt_Click" Margin="5,0,0,0"/>
                    </StackPanel>
                    <ListBox x:Name="AllTrackersListBox" Grid.Row="1"
                             Background="{StaticResource BgSurfaceBrush}" Foreground="{StaticResource TextPrimaryBrush}" BorderThickness="0"
                             SelectionMode="Single">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Foreground="{StaticResource TextPrimaryBrush}" Padding="5"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </TabItem>
            <TabItem Header="自定义 Tracker" Style="{StaticResource ModernTabItem}">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBox x:Name="CustomTrackerTextBox"
                                 Style="{StaticResource ModernTextBox}"
                                 Width="450"/>
                        <Button Content="添加自定义" Style="{StaticResource PrimaryButton}" Click="AddCustomTracker_Click" Margin="10,0,0,0"/>
                    </StackPanel>
                    <ListBox x:Name="CustomTrackersListBox" Grid.Row="1"
                             Background="{StaticResource BgSurfaceBrush}" Foreground="{StaticResource TextPrimaryBrush}" BorderThickness="0"
                             SelectionMode="Single">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Foreground="{StaticResource TextPrimaryBrush}" Padding="5"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="删除选中" Style="{StaticResource DangerButton}" Click="DeleteSelected_Click"/>
            <Button Content="关闭" Style="{StaticResource BaseButton}" Click="CloseButton_Click" Margin="10,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>
