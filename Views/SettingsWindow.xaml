<Window x:Class="IsparkDownloader2.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="设置" 
        Height="500" Width="600"
        WindowStartupLocation="CenterOwner"
        Background="#FF1E1E1E"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="SettingLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,15,0"/>
        </Style>

        <Style x:Key="SettingTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#FF2D2D2D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#FF3C3C3C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="CaretBrush" Value="White"/>
        </Style>

        <Style x:Key="SettingCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#FF3C3C3C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF505050"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#FF0078D4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF106EBE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="设置" Foreground="White" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- 下载设置 -->
                <TextBlock Text="下载设置" Foreground="#FF0078D4" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10"/>

                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="默认保存路径:" Style="{StaticResource SettingLabel}"/>
                    <Grid Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="SavePathTextBox" Style="{StaticResource SettingTextBox}" Grid.Column="0"/>
                        <Button Content="浏览..." Style="{StaticResource ModernButton}" Grid.Column="1" 
                                Margin="5,0,0,0" Padding="12,6" Click="BrowseButton_Click"/>
                    </Grid>
                </Grid>

                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="默认线程数:" Style="{StaticResource SettingLabel}"/>
                    <TextBox x:Name="ThreadCountTextBox" Style="{StaticResource SettingTextBox}" Grid.Column="1"/>
                </Grid>

                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="最大同时下载:" Style="{StaticResource SettingLabel}"/>
                    <TextBox x:Name="MaxConcurrentTextBox" Style="{StaticResource SettingTextBox}" Grid.Column="1"/>
                </Grid>

                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="速度限制 (KB/s):" Style="{StaticResource SettingLabel}"/>
                    <TextBox x:Name="SpeedLimitTextBox" Style="{StaticResource SettingTextBox}" Grid.Column="1"/>
                </Grid>

                <Separator Margin="0,15" Background="#FF3C3C3C"/>

                <!-- 行为设置 -->
                <TextBlock Text="行为设置" Foreground="#FF0078D4" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10"/>

                <CheckBox x:Name="AutoStartCheckBox" Content="添加任务后自动开始下载" Style="{StaticResource SettingCheckBox}" Margin="0,5"/>
                <CheckBox x:Name="NotificationCheckBox" Content="下载完成后显示通知" Style="{StaticResource SettingCheckBox}" Margin="0,5"/>
                <CheckBox x:Name="AutoRemoveCheckBox" Content="自动清除已完成的任务" Style="{StaticResource SettingCheckBox}" Margin="0,5"/>

                <Separator Margin="0,15" Background="#FF3C3C3C"/>

                <!-- 更新设置 -->
                <TextBlock Text="更新设置" Foreground="#FF0078D4" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10"/>

                <CheckBox x:Name="AutoCheckUpdateCheckBox" Content="启动时自动检查更新" Style="{StaticResource SettingCheckBox}" Margin="0,5"/>

                <Grid Margin="0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="手动检查是否有新版本可用" Foreground="#FF8B8BA7" FontSize="12" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="检查更新" Style="{StaticResource ModernButton}" Padding="12,6" Click="CheckUpdate_Click"/>
                </Grid>

                <Separator Margin="0,15" Background="#FF3C3C3C"/>

                <!-- 网络设置 -->
                <TextBlock Text="网络设置" Foreground="#FF0078D4" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10"/>

                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="连接超时 (秒):" Style="{StaticResource SettingLabel}"/>
                    <TextBox x:Name="TimeoutTextBox" Style="{StaticResource SettingTextBox}" Grid.Column="1"/>
                </Grid>

                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="重试次数:" Style="{StaticResource SettingLabel}"/>
                    <TextBox x:Name="RetryCountTextBox" Style="{StaticResource SettingTextBox}" Grid.Column="1"/>
                </Grid>

                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="User-Agent:" Style="{StaticResource SettingLabel}"/>
                    <TextBox x:Name="UserAgentTextBox" Style="{StaticResource SettingTextBox}" Grid.Column="1"/>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <!-- 按钮 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="保存" Style="{StaticResource ActionButton}" Click="SaveButton_Click"/>
            <Button Content="取消" Style="{StaticResource ModernButton}" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
