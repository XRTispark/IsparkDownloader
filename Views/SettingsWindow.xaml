<Window x:Class="IsparkDownloader2.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置"
        Height="560" Width="640"
        Style="{StaticResource ModernWindow}"
        ResizeMode="CanResize">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="&#x2699; 设置" Foreground="{StaticResource TextPrimaryBrush}" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Download Settings -->
                <TextBlock Text="下载设置" Foreground="{StaticResource AccentBrush}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <Grid Margin="0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="默认保存路径:" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            <Grid Grid.Column="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="SavePathTextBox" Style="{StaticResource ModernTextBox}" Grid.Column="0"/>
                                <Button Content="浏览..." Style="{StaticResource BaseButton}" Grid.Column="1" Click="BrowseButton_Click" Padding="12,6" Margin="6,0,0,0"/>
                            </Grid>
                        </Grid>
                        <Grid Margin="0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="最大线程数:" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBox x:Name="MaxThreadsTextBox" Style="{StaticResource ModernTextBox}" Grid.Column="1"/>
                        </Grid>
                        <Grid Margin="0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="速度限制 (KB/s):" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBox x:Name="SpeedLimitTextBox" Style="{StaticResource ModernTextBox}" Grid.Column="1"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Separator Style="{StaticResource ModernSeparator}"/>

                <!-- Behavior Settings -->
                <TextBlock Text="行为设置" Foreground="{StaticResource AccentBrush}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <CheckBox x:Name="AutoStartCheckBox" Content="添加任务后自动开始下载" Style="{StaticResource ModernCheckBox}"/>
                        <CheckBox x:Name="NotificationCheckBox" Content="下载完成后显示通知" Style="{StaticResource ModernCheckBox}"/>
                        <CheckBox x:Name="AutoRemoveCheckBox" Content="自动清除已完成的任务" Style="{StaticResource ModernCheckBox}"/>
                    </StackPanel>
                </Border>

                <Separator Style="{StaticResource ModernSeparator}"/>

                <!-- Update Settings -->
                <TextBlock Text="更新设置" Foreground="{StaticResource AccentBrush}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <CheckBox x:Name="AutoCheckUpdateCheckBox" Content="启动时自动检查更新" Style="{StaticResource ModernCheckBox}"/>
                        <Grid Margin="0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="手动检查是否有新版本可用" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="检查更新" Style="{StaticResource PrimaryButton}" Padding="12,6" Click="CheckUpdate_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Separator Style="{StaticResource ModernSeparator}"/>

                <!-- Network Settings -->
                <TextBlock Text="网络设置" Foreground="{StaticResource AccentBrush}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <Grid Margin="0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="连接超时 (秒):" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBox x:Name="TimeoutTextBox" Style="{StaticResource ModernTextBox}" Grid.Column="1"/>
                        </Grid>
                        <Grid Margin="0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="重试次数:" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBox x:Name="RetryCountTextBox" Style="{StaticResource ModernTextBox}" Grid.Column="1"/>
                        </Grid>
                        <Grid Margin="0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="User-Agent:" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBox x:Name="UserAgentTextBox" Style="{StaticResource ModernTextBox}" Grid.Column="1"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="保存" Style="{StaticResource PrimaryButton}" Click="SaveButton_Click" Padding="24,8"/>
            <Button Content="取消" Style="{StaticResource BaseButton}" Click="CancelButton_Click" Padding="24,8"/>
        </StackPanel>
    </Grid>
</Window>
