<Window x:Class="IsparkDownloader2.Views.CloudDriveConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="网盘账号配置"
        Height="500" Width="700"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="{StaticResource FontFamilyBase}"
        FontSize="13"
        ResizeMode="CanResize">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="网盘账号管理" Foreground="{StaticResource TextPrimaryBrush}" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

        <TabControl Grid.Row="1" Style="{StaticResource ModernTabControl}">
            <!-- 百度网盘 -->
            <TabItem Header="百度网盘" Style="{StaticResource ModernTabItem}">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="百度网盘开放平台 OAuth2 配置" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13" Margin="0,0,0,10"/>

                    <Grid Grid.Row="1" Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="AppKey:" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" x:Name="BaiduClientId" Style="{StaticResource ModernTextBox}"/>
                    </Grid>

                    <Grid Grid.Row="2" Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="SecretKey:" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" x:Name="BaiduClientSecret" Style="{StaticResource ModernTextBox}"/>
                    </Grid>

                    <Grid Grid.Row="3" Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="授权码:" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" x:Name="BaiduAuthCode" Style="{StaticResource ModernTextBox}"/>
                    </Grid>

                    <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,10">
                        <Button Content="获取授权链接" Style="{StaticResource BaseButton}" Click="GetBaiduAuthUrl_Click"/>
                        <Button Content="登录" Style="{StaticResource PrimaryButton}" Click="BaiduLogin_Click"/>
                        <Button Content="登出" Style="{StaticResource DangerButton}" Click="BaiduLogout_Click"/>
                    </StackPanel>

                    <Border Grid.Row="5" Background="{StaticResource BgSurfaceBrush}" CornerRadius="6" Padding="10">
                        <TextBlock x:Name="BaiduStatusText" Text="未登录" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                    </Border>
                </Grid>
            </TabItem>

            <!-- 阿里云盘 -->
            <TabItem Header="阿里云盘" Style="{StaticResource ModernTabItem}">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="阿里云盘开放平台 OAuth2 配置" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13" Margin="0,0,0,10"/>

                    <Grid Grid.Row="1" Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Client ID:" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" x:Name="AliyunClientId" Style="{StaticResource ModernTextBox}"/>
                    </Grid>

                    <Grid Grid.Row="2" Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Secret:" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" x:Name="AliyunClientSecret" Style="{StaticResource ModernTextBox}"/>
                    </Grid>

                    <Grid Grid.Row="3" Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="授权码:" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" x:Name="AliyunAuthCode" Style="{StaticResource ModernTextBox}"/>
                    </Grid>

                    <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,10">
                        <Button Content="获取授权链接" Style="{StaticResource BaseButton}" Click="GetAliyunAuthUrl_Click"/>
                        <Button Content="登录" Style="{StaticResource PrimaryButton}" Click="AliyunLogin_Click"/>
                        <Button Content="登出" Style="{StaticResource DangerButton}" Click="AliyunLogout_Click"/>
                    </StackPanel>

                    <Border Grid.Row="5" Background="{StaticResource BgSurfaceBrush}" CornerRadius="6" Padding="10">
                        <TextBlock x:Name="AliyunStatusText" Text="未登录" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                    </Border>
                </Grid>
            </TabItem>

            <!-- 夸克网盘 -->
            <TabItem Header="夸克网盘" Style="{StaticResource ModernTabItem}">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="夸克网盘 Cookie 登录" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13" Margin="0,0,0,10"/>
                    <TextBlock Grid.Row="1" Text="夸克网盘未提供官方开放平台，需手动获取 Cookie 中的 ctoken" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,10"/>

                    <Grid Grid.Row="2" Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="ctoken:" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" x:Name="QuarkToken" Style="{StaticResource ModernTextBox}"/>
                    </Grid>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,10">
                        <Button Content="登录" Style="{StaticResource PrimaryButton}" Click="QuarkLogin_Click"/>
                        <Button Content="登出" Style="{StaticResource DangerButton}" Click="QuarkLogout_Click"/>
                    </StackPanel>

                    <Border Grid.Row="4" Background="{StaticResource BgSurfaceBrush}" CornerRadius="6" Padding="10">
                        <TextBlock x:Name="QuarkStatusText" Text="未登录&#x0a;获取方式: 登录 pan.quark.cn 后，在浏览器开发者工具(F12)的 Application/Cookies 中查找 ctoken 值" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <Button Grid.Row="2" Content="关闭" Style="{StaticResource BaseButton}" HorizontalAlignment="Right"
                Click="CloseButton_Click" Margin="0,10,0,0" Padding="20,8"/>
    </Grid>
</Window>
