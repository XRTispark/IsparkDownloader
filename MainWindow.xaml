<Window x:Class="IsparkDownloader2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:IsparkDownloader2.ViewModels"
        xmlns:conv="clr-namespace:IsparkDownloader2.Converters"
        mc:Ignorable="d"
        Title="IsparkDownloader2 - 现代化下载工具" 
        Height="700" Width="1100"
        MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="#FF1E1E1E">

    <Window.DataContext>
        <vm:MainViewModel x:Name="ViewModel"/>
    </Window.DataContext>

    <Window.Resources>
        <conv:StatusToColorConverter x:Key="StatusToColorConverter"/>
        <conv:SpeedToVisibilityConverter x:Key="SpeedToVisibilityConverter"/>

        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#FF3C3C3C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF505050"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FF2A2A2A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#FF0078D4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF106EBE"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FF005A9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#FFD32F2F"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FFC62828"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FFB71C1C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#FF2D2D2D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#FF3C3C3C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernListView" TargetType="ListView">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <DataTemplate x:Key="TaskItemTemplate">
            <Border Background="#FF2D2D2D" CornerRadius="6" Margin="0,4" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 第一行：文件名、类型标签和状态 -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- BT 类型标签 -->
                        <Border Grid.Column="0" 
                                Background="#FF0078D4" 
                                CornerRadius="3" 
                                Padding="5,2" 
                                Margin="0,0,8,0"
                                VerticalAlignment="Center">
                            <TextBlock Text="{Binding Type}" 
                                       Foreground="White" 
                                       FontSize="10"
                                       FontWeight="Bold"/>
                        </Border>

                        <TextBlock Grid.Column="1" 
                                   Text="{Binding FileName}" 
                                   Foreground="White" 
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" 
                                   Text="{Binding StatusText}" 
                                   Foreground="{Binding Status, Converter={StaticResource StatusToColorConverter}}"
                                   FontSize="12"
                                   Margin="10,0,0,0"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <!-- 第二行：进度条 -->
                    <Grid Grid.Row="1" Margin="0,8">
                        <Border Background="#FF1E1E1E" CornerRadius="3" Height="6" x:Name="ProgressBarBg">
                            <Border Background="#FF0078D4" 
                                    CornerRadius="3"
                                    HorizontalAlignment="Left">
                                <Border.Width>
                                    <MultiBinding Converter="{StaticResource ProgressToWidthConverter}">
                                        <Binding Path="Progress"/>
                                        <Binding ElementName="ProgressBarBg" Path="ActualWidth"/>
                                    </MultiBinding>
                                </Border.Width>
                            </Border>
                        </Border>
                    </Grid>

                    <!-- 第三行：大小、速度、种子/用户数、进度百分比 -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding SizeText}" 
                                   Foreground="#FFAAAAAA" 
                                   FontSize="11"
                                   VerticalAlignment="Center"/>

                        <!-- BT 种子/用户数 -->
                        <TextBlock Grid.Column="1" 
                                   Text="{Binding SeedsPeersText}" 
                                   Foreground="#FF81C784"
                                   FontSize="11"
                                   Margin="10,0,0,0"
                                   VerticalAlignment="Center"/>

                        <TextBlock Grid.Column="2" 
                                   Text="{Binding SpeedText}" 
                                   Foreground="#FF4FC3F7"
                                   FontSize="11"
                                   Margin="10,0,0,0"
                                   Visibility="{Binding Speed, Converter={StaticResource SpeedToVisibilityConverter}}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="3" 
                                   Text="{Binding Progress, StringFormat={}{0}%}" 
                                   Foreground="White"
                                   FontSize="11"
                                   Margin="10,0,0,0"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Border Grid.Row="0" Background="#FF252525" Padding="15,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="IsparkDownloader2" 
                           Foreground="White" 
                           FontSize="18" 
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" 
                           Text="现代化下载工具" 
                           Foreground="#FFAAAAAA" 
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="10,0,0,0"/>
                <Button Grid.Column="2" 
                        Content="设置" 
                        Style="{StaticResource ModernButton}"
                        Command="{Binding ShowSettingsCommand}"
                        Padding="12,6"/>
            </Grid>
        </Border>

        <!-- 添加任务区域 -->
        <Border Grid.Row="1" Background="#FF252525" Padding="15" Margin="0,1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Row="0" Grid.Column="0" 
                         Style="{StaticResource ModernTextBox}"
                         Text="{Binding NewUrl, UpdateSourceTrigger=PropertyChanged}"
                         VerticalContentAlignment="Center"
                         FontSize="13">
                    <TextBox.ToolTip>
                        <ToolTip Content="输入下载链接 (支持 HTTP/HTTPS/FTP/磁力链接)"/>
                    </TextBox.ToolTip>
                </TextBox>
                <Button Grid.Row="0" Grid.Column="1" 
                        Content="添加任务" 
                        Style="{StaticResource ActionButton}"
                        Command="{Binding AddTaskCommand}"
                        Margin="10,0,0,0"
                        FontSize="13"/>
                <Button Grid.Row="0" Grid.Column="2" 
                        Content="浏览..." 
                        Style="{StaticResource ModernButton}"
                        Command="{Binding BrowseSavePathCommand}"
                        Margin="5,0,0,0"
                        FontSize="13"/>

            </Grid>
        </Border>

        <!-- 任务列表 -->
        <Border Grid.Row="2" Background="#FF1E1E1E" Margin="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 工具栏 -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                    <Button Content="开始" 
                            Style="{StaticResource ActionButton}"
                            Command="{Binding StartTaskCommand}"
                            Padding="15,6"/>
                    <Button Content="暂停" 
                            Style="{StaticResource ModernButton}"
                            Command="{Binding PauseTaskCommand}"
                            Padding="15,6"/>
                    <Button Content="删除" 
                            Style="{StaticResource DangerButton}"
                            Command="{Binding RemoveTaskCommand}"
                            Padding="15,6"/>
                    <Separator Margin="10,0" Background="#FF3C3C3C" Style="{x:Null}" Width="1"/>
                    <Button Content="全部开始" 
                            Style="{StaticResource ActionButton}"
                            Command="{Binding StartAllCommand}"
                            Padding="15,6"/>
                    <Button Content="全部暂停" 
                            Style="{StaticResource ModernButton}"
                            Command="{Binding PauseAllCommand}"
                            Padding="15,6"/>
                    <Button Content="清除已完成" 
                            Style="{StaticResource ModernButton}"
                            Command="{Binding RemoveCompletedCommand}"
                            Padding="15,6"/>
                    <Button Content="打开文件夹" 
                            Style="{StaticResource ModernButton}"
                            Command="{Binding OpenFolderCommand}"
                            Padding="15,6"/>
                    <Separator Margin="10,0" Background="#FF3C3C3C" Style="{x:Null}" Width="1"/>
                    <!-- BT 相关按钮 -->
                    <Button Content="选择种子" 
                            Style="{StaticResource ActionButton}"
                            Command="{Binding SelectTorrentFileCommand}"
                            Padding="15,6"/>
                    <Button Content="BT 详情" 
                            Style="{StaticResource ModernButton}"
                            Command="{Binding ShowTorrentDetailCommand}"
                            Padding="15,6"/>
                    <Button Content="Tracker" 
                            Style="{StaticResource ModernButton}"
                            Command="{Binding ShowTrackerConfigCommand}"
                            Padding="15,6"/>
                    <Separator Margin="10,0" Background="#FF3C3C3C" Style="{x:Null}" Width="1"/>
                    <!-- 网盘相关按钮 -->
                    <Button Content="网盘配置" 
                            Style="{StaticResource ModernButton}"
                            Command="{Binding ShowCloudDriveConfigCommand}"
                            Padding="15,6"/>
                    <Button Content="解析分享" 
                            Style="{StaticResource ActionButton}"
                            Command="{Binding ParseCloudShareCommand}"
                            Padding="15,6"/>
                    <Separator Margin="10,0" Background="#FF3C3C3C" Style="{x:Null}" Width="1"/>
                    <!-- 更新按钮 -->
                    <Button Content="检查更新" 
                            Style="{StaticResource ModernButton}"
                            Command="{Binding CheckUpdateCommand}"
                            Padding="15,6"/>
                </StackPanel>

                <!-- 列表 -->
                <ListView Grid.Row="1" 
                          Style="{StaticResource ModernListView}"
                          ItemsSource="{Binding Tasks}"
                          SelectedItem="{Binding SelectedTask}"
                          ItemTemplate="{StaticResource TaskItemTemplate}"
                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,2"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#FF3C3C3C"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#FF333333"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>
            </Grid>
        </Border>

        <!-- 状态栏 -->
        <Border Grid.Row="3" Background="#FF252525" Padding="15,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding StatusText}" 
                           Foreground="#FFAAAAAA" 
                           FontSize="12"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" 
                           Text="v2.0.0" 
                           Foreground="#FF666666" 
                           FontSize="11"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
