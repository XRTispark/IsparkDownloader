<Window x:Class="IsparkDownloader2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:IsparkDownloader2.ViewModels"
        xmlns:conv="clr-namespace:IsparkDownloader2.Converters"
        mc:Ignorable="d"
        Title="IsparkDownloader" 
        Height="720" Width="1200"
        MinHeight="520" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource ModernWindow}">

    <Window.DataContext>
        <vm:MainViewModel x:Name="ViewModel"/>
    </Window.DataContext>

    <Window.Resources>
        <conv:StatusToColorConverter x:Key="StatusToColorConverter"/>
        <conv:SpeedToVisibilityConverter x:Key="SpeedToVisibilityConverter"/>

        <DataTemplate x:Key="TaskItemTemplate">
            <Border Background="{StaticResource BgElevatedBrush}" CornerRadius="10" Padding="14" Margin="0,3">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Row 1: File name, type badge, status -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="{StaticResource AccentBrush}"
                                CornerRadius="4"
                                Padding="6,3"
                                Margin="0,0,10,0"
                                VerticalAlignment="Center">
                            <TextBlock Text="{Binding Type}"
                                       Foreground="#0D1117"
                                       FontSize="10"
                                       FontWeight="Bold"/>
                        </Border>

                        <TextBlock Grid.Column="1"
                                   Text="{Binding FileName}"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center"/>

                        <TextBlock Grid.Column="2"
                                   Text="{Binding StatusText}"
                                   Foreground="{Binding Status, Converter={StaticResource StatusToColorConverter}}"
                                   FontSize="12"
                                   Margin="10,0,0,0"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Row 2: Progress bar -->
                    <Grid Grid.Row="1" Margin="0,10">
                        <Border Background="{StaticResource BgSurfaceBrush}" CornerRadius="4" Height="8" x:Name="ProgressBarBg">
                            <Border Background="{StaticResource AccentBrush}"
                                    CornerRadius="4"
                                    HorizontalAlignment="Left">
                                <Border.Width>
                                    <MultiBinding Converter="{StaticResource ProgressToWidthConverter}">
                                        <Binding Path="Progress"/>
                                        <Binding ElementName="ProgressBarBg" Path="ActualWidth"/>
                                    </MultiBinding>
                                </Border.Width>
                            </Border>
                        </Border>
                    </Grid>

                    <!-- Row 3: Size, seeds, speed, percentage -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding SizeText}"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="11"
                                   VerticalAlignment="Center"/>

                        <TextBlock Grid.Column="1"
                                   Text="{Binding SeedsPeersText}"
                                   Foreground="{StaticResource SuccessBrush}"
                                   FontSize="11"
                                   Margin="12,0,0,0"
                                   VerticalAlignment="Center"/>

                        <TextBlock Grid.Column="2"
                                   Text="{Binding SpeedText}"
                                   Foreground="{StaticResource InfoBrush}"
                                   FontSize="11"
                                   Margin="12,0,0,0"
                                   Visibility="{Binding Speed, Converter={StaticResource SpeedToVisibilityConverter}}"
                                   VerticalAlignment="Center"/>

                        <TextBlock Grid.Column="3"
                                   Text="{Binding Progress, StringFormat={}{0}%}"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="11"
                                   Margin="12,0,0,0"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Border Grid.Row="0" Background="{StaticResource BgElevatedBrush}" Padding="18,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#x2B07;" FontSize="20" Foreground="{StaticResource AccentBrush}" Margin="0,0,10,0"/>
                    <TextBlock Text="IsparkDownloader"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="18"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="v2.0.0"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="11"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0"/>
                </StackPanel>
                <Button Grid.Column="2"
                        Content="&#x2699; 设置"
                        Style="{StaticResource GhostButton}"
                        Command="{Binding ShowSettingsCommand}"
                        Padding="10,6"/>
            </Grid>
        </Border>

        <!-- Add task area -->
        <Border Grid.Row="1" Background="{StaticResource BgElevatedBrush}" Padding="18,14" Margin="0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Style="{StaticResource ModernTextBox}"
                         Text="{Binding NewUrl, UpdateSourceTrigger=PropertyChanged}"
                         VerticalContentAlignment="Center"
                         FontSize="13">
                    <TextBox.ToolTip>
                        <ToolTip Content="输入下载链接 (支持 HTTP/HTTPS/FTP/磁力链接/网盘分享)"/>
                    </TextBox.ToolTip>
                </TextBox>
                <Button Grid.Column="1"
                        Content="&#x2795; 添加任务"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding AddTaskCommand}"
                        Margin="10,0,0,0"
                        FontSize="13"/>
                <Button Grid.Column="2"
                        Content="&#x1F4C1;"
                        Style="{StaticResource BaseButton}"
                        Command="{Binding BrowseSavePathCommand}"
                        Margin="6,0,0,0"
                        FontSize="14"
                        Padding="10,7"/>
            </Grid>
        </Border>

        <!-- Task list -->
        <Border Grid.Row="2" Background="{StaticResource BgBrush}" Padding="18,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Toolbar -->
                <WrapPanel Grid.Row="0" Margin="0,0,0,12">
                    <Button Content="&#x25B6; 开始"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding StartTaskCommand}"
                            Padding="12,6"/>
                    <Button Content="&#x23F8; 暂停"
                            Style="{StaticResource BaseButton}"
                            Command="{Binding PauseTaskCommand}"
                            Padding="12,6"/>
                    <Button Content="&#x1F5D1; 删除"
                            Style="{StaticResource DangerButton}"
                            Command="{Binding RemoveTaskCommand}"
                            Padding="12,6"/>
                    <Rectangle Width="1" Height="24" Fill="{StaticResource BorderBrush}" Margin="8,4"/>
                    <Button Content="&#x25B6;&#x25B6; 全部开始"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding StartAllCommand}"
                            Padding="12,6"/>
                    <Button Content="&#x23F8;&#x23F8; 全部暂停"
                            Style="{StaticResource BaseButton}"
                            Command="{Binding PauseAllCommand}"
                            Padding="12,6"/>
                    <Button Content="&#x2713; 清除已完成"
                            Style="{StaticResource BaseButton}"
                            Command="{Binding RemoveCompletedCommand}"
                            Padding="12,6"/>
                    <Button Content="&#x1F4C2; 打开文件夹"
                            Style="{StaticResource BaseButton}"
                            Command="{Binding OpenFolderCommand}"
                            Padding="12,6"/>
                    <Rectangle Width="1" Height="24" Fill="{StaticResource BorderBrush}" Margin="8,4"/>
                    <Button Content="&#x1F4E5; 种子"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding SelectTorrentFileCommand}"
                            Padding="12,6"/>
                    <Button Content="&#x1F527; Tracker"
                            Style="{StaticResource BaseButton}"
                            Command="{Binding ShowTrackerConfigCommand}"
                            Padding="12,6"/>
                    <Rectangle Width="1" Height="24" Fill="{StaticResource BorderBrush}" Margin="8,4"/>
                    <Button Content="&#x2601; 网盘"
                            Style="{StaticResource BaseButton}"
                            Command="{Binding ShowCloudDriveConfigCommand}"
                            Padding="12,6"/>
                    <Button Content="&#x1F517; 解析分享"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding ParseCloudShareCommand}"
                            Padding="12,6"/>
                    <Rectangle Width="1" Height="24" Fill="{StaticResource BorderBrush}" Margin="8,4"/>
                    <Button Content="&#x1F504; 检查更新"
                            Style="{StaticResource BaseButton}"
                            Command="{Binding CheckUpdateCommand}"
                            Padding="12,6"/>
                </WrapPanel>

                <!-- List -->
                <ListView Grid.Row="1"
                          Style="{StaticResource ModernListView}"
                          ItemsSource="{Binding Tasks}"
                          SelectedItem="{Binding SelectedTask}"
                          ItemTemplate="{StaticResource TaskItemTemplate}"
                          ItemContainerStyle="{StaticResource ModernListViewItem}"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"/>
            </Grid>
        </Border>

        <!-- Status bar -->
        <Border Grid.Row="3" Background="{StaticResource BgElevatedBrush}" Padding="18,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding StatusText}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           Text="IsparkDownloader v2.0.0"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="11"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
